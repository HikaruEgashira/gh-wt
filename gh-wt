#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/backend.sh"
source "$SCRIPT_DIR/lib/cache.sh"
source "$SCRIPT_DIR/lib/deps.sh"
source "$SCRIPT_DIR/lib/overlay.sh"
source "$SCRIPT_DIR/lib/worktree.sh"

usage() {
    cat <<'EOF'
Usage:
  gh wt add <branch> [path]  Create a worktree session (overlay or plain)
  gh wt list                 List worktrees (wraps git worktree list)
  gh wt remove               Select a session via fzf and remove it
  gh wt gc                   Delete unreferenced cache entries
  gh wt doctor               Verify the selected backend is healthy
  gh wt set-backend <value>  Persist the backend choice to XDG config
  gh wt -- <command>         Run <command> inside the selected session dir
  gh wt <command>            Run <command> with selected session path as arg

Overlay backends require: Linux 5.11+ with OverlayFS (root/passwordless sudo),
  macOS 26+ with the gh-wt-overlay FSKit extension, or macOS + macFUSE.
The `none` backend is portable and uses plain `git worktree add`.

Backend selection (precedence: env > config > auto):
  GH_WT_BACKEND=auto|overlayfs|fskit|macfuse|none
  config file: ${XDG_CONFIG_HOME:-~/.config}/gh-wt/config

backend=none creates worktrees asynchronously: `git worktree add --no-checkout`
returns immediately, then a detached `git reset --hard HEAD` streams files in
(see .gh-wt-checkout.log in the worktree for progress/errors).
EOF
}

cmd="${1:-}"
case "$cmd" in
    "" | "-h" | "--help")
        usage
        ;;
    add)
        shift
        require_env
        cmd_add "$@"
        ;;
    list)
        require_env
        cmd_list
        ;;
    remove | rm)
        require_env
        cmd_remove
        ;;
    gc)
        require_env
        cmd_gc
        ;;
    doctor)
        cmd_doctor
        ;;
    set-backend)
        shift
        cmd_set_backend "$@"
        ;;
    --)
        shift
        require_env
        cmd_exec_in "$@"
        ;;
    *)
        require_env
        cmd_exec_with "$@"
        ;;
esac

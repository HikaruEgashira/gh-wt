#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/worktree.sh"
source "$SCRIPT_DIR/lib/overlay.sh"
source "$SCRIPT_DIR/lib/session.sh"

usage() {
    cat <<'EOF'
Usage:
  gh wt add <branch> [path]  Create an overlay worktree session
  gh wt list                 List git worktrees in current repository
  gh wt remove               Select a worktree via fzf and remove it
  gh wt gc                   Remove unreferenced overlay references
  gh wt doctor               Check environment for overlay support
  gh wt -- <command>         Select a worktree via fzf and run <command> there
  gh wt <command>            Select a worktree via fzf and run <command> <path>
EOF
}

cmd="${1:-}"

case "$cmd" in
    ""|-h|--help)
        usage
        ;;

    add)
        if [[ -z "${2:-}" ]]; then
            echo "Error: branch name is required" >&2
            echo "Usage: gh wt add <branch> [path]" >&2
            exit 1
        fi
        repo=$(require_main_repo)
        branch="$2"
        if [[ -n "${3:-}" ]]; then
            mountpoint="$3"
        else
            mountpoint=$(default_mountpoint "$repo" "$branch")
        fi
        case "$mountpoint" in
            /*) ;;
            *)  mountpoint="$(pwd)/$mountpoint" ;;
        esac
        echo "Creating overlay worktree:"
        echo "  repo:       $repo"
        echo "  branch:     $branch"
        echo "  mountpoint: $mountpoint"
        session_add "$repo" "$branch" "$mountpoint"
        echo "Worktree created."
        ;;

    list|ls)
        repo=$(require_main_repo)
        (cd "$repo" && git worktree list)
        ;;

    remove|rm)
        repo=$(require_main_repo)
        selected=$(select_worktree "$repo" "Select worktree to remove: ") || exit 0
        [[ -z "$selected" ]] && exit 0
        main=$(cd "$repo" && git rev-parse --show-toplevel)
        if [[ "$selected" == "$main" ]]; then
            echo "Error: refusing to remove the main worktree" >&2
            exit 1
        fi
        echo "Removing worktree: $selected"
        session_remove "$repo" "$selected"
        echo "Worktree removed."
        ;;

    gc)
        repo=$(require_main_repo)
        session_gc "$repo"
        ;;

    doctor)
        session_doctor
        ;;

    --)
        shift
        repo=$(require_main_repo)
        selected=$(select_worktree "$repo") || exit 0
        [[ -z "$selected" ]] && exit 0
        cd "$selected"
        exec "$@"
        ;;

    *)
        repo=$(require_main_repo)
        selected=$(select_worktree "$repo") || exit 0
        [[ -z "$selected" ]] && exit 0
        exec "$@" "$selected"
        ;;
esac

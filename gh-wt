#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/backend.sh"
source "$SCRIPT_DIR/lib/cache.sh"
source "$SCRIPT_DIR/lib/overlay.sh"
source "$SCRIPT_DIR/lib/worktree.sh"

usage() {
    cat <<'EOF'
Usage:
  gh wt add <branch> [path]  Create an overlay-backed worktree session
  gh wt list                 List worktrees (wraps git worktree list)
  gh wt remove               Select a session via fzf and remove it
  gh wt gc                   Delete unreferenced cache entries
  gh wt doctor               Verify the platform overlay backend is healthy
  gh wt -- <command>         Run <command> inside the selected session dir
  gh wt <command>            Run <command> with selected session path as arg

Requires: Linux 5.11+ with OverlayFS (root or passwordless sudo), OR
          macOS 26+ with the gh-wt-overlay FSKit System Extension, OR
          macOS with macFUSE + gh-wt-mount-overlay-fuse helper.

Backend selection:
  GH_WT_BACKEND=auto|overlayfs|fskit|macfuse (default: auto)
EOF
}

cmd="${1:-}"
case "$cmd" in
    "" | "-h" | "--help")
        usage
        ;;
    add)
        shift
        require_env
        cmd_add "$@"
        ;;
    list)
        require_env
        cmd_list
        ;;
    remove | rm)
        require_env
        cmd_remove
        ;;
    gc)
        require_env
        cmd_gc
        ;;
    doctor)
        cmd_doctor
        ;;
    --)
        shift
        require_env
        cmd_exec_in "$@"
        ;;
    *)
        require_env
        cmd_exec_with "$@"
        ;;
esac

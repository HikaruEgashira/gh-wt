#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/backend.sh"
source "$SCRIPT_DIR/lib/cache.sh"
source "$SCRIPT_DIR/lib/deps.sh"
source "$SCRIPT_DIR/lib/overlay.sh"
source "$SCRIPT_DIR/lib/worktree.sh"

usage() {
    cat <<'EOF'
Usage:
  gh wt add [--new|-b] <branch> [path]
                             Create a worktree. --new opts into creating a
                             new branch from HEAD when <branch> does not
                             exist locally or as origin/<branch>; otherwise
                             gh-wt prompts (TTY) or refuses (non-TTY).
                             GH_WT_ASSUME_NEW=1 scripts the --new path.
  gh wt list                 List worktrees (wraps git worktree list)
  gh wt remove [target]      Remove a worktree; target may be a path or a
                             branch name. Omit to pick via fzf.
  gh wt gc                   Delete unreferenced cache entries
  gh wt -- <command>         Run <command> inside the selected worktree
  gh wt <command>            Run <command> with the selected worktree path as arg
EOF
}

cmd="${1:-}"
case "$cmd" in
    "" | "-h" | "--help")
        usage
        ;;
    add)
        shift
        require_env
        cmd_add "$@"
        ;;
    list)
        require_env
        cmd_list
        ;;
    remove | rm)
        shift
        require_env
        cmd_remove "$@"
        ;;
    gc)
        require_env
        cmd_gc
        ;;
    --)
        shift
        require_env
        cmd_exec_in "$@"
        ;;
    *)
        require_env
        cmd_exec_with "$@"
        ;;
esac

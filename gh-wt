#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/backend.sh"
source "$SCRIPT_DIR/lib/cache.sh"
source "$SCRIPT_DIR/lib/deps.sh"
source "$SCRIPT_DIR/lib/overlay.sh"
source "$SCRIPT_DIR/lib/worktree.sh"

usage() {
    cat <<'EOF'
Usage:
  gh wt add [--new|-b] <branch> [path]
                             Create a worktree. --new opts into creating a
                             new branch from HEAD when <branch> does not
                             exist locally or as origin/<branch>; otherwise
                             gh-wt prompts (TTY) or refuses (non-TTY).
                             GH_WT_ASSUME_NEW=1 scripts the --new path.
  gh wt list                 List worktrees (wraps git worktree list)
  gh wt remove [target]      Remove a worktree; target may be a path or a
                             branch name. Omit to pick via fzf.
  gh wt gc                   Delete unreferenced cache entries
  gh wt [--at <wt>] -- <cmd> Run <cmd> inside the selected worktree
  gh wt [--at <wt>] <cmd>    Run <cmd> with the selected worktree path as arg

Selection (for the last two forms and `gh wt remove`):
  --at <branch|path>         Bypass fzf — resolve <wt> against the registered
                             worktree list. Required in non-interactive runs.
  GH_WT_NONINTERACTIVE=1     Refuse to spawn fzf; print candidates + exit 2.
                             fzf still short-circuits when there's only one
                             worktree even without these (--select-1).
EOF
}

# --at <wt> may appear before the subcommand to pin the selection without
# fzf. Strip it from argv so the case-statement below still sees the bare
# subcommand. Two-pass parse (here + per-cmd) keeps the existing positional
# layouts untouched.
target=""
if [[ "${1:-}" == "--at" ]]; then
    [[ $# -ge 2 ]] || { echo "gh-wt: --at requires <branch|path>" >&2; exit 1; }
    target="$2"
    shift 2
fi

cmd="${1:-}"
case "$cmd" in
    "" | "-h" | "--help")
        usage
        ;;
    add)
        [[ -z "$target" ]] || { echo "gh-wt: --at is not valid with 'add'" >&2; exit 1; }
        shift
        require_env
        cmd_add "$@"
        ;;
    list)
        [[ -z "$target" ]] || { echo "gh-wt: --at is not valid with 'list'" >&2; exit 1; }
        require_env
        cmd_list
        ;;
    remove | rm)
        shift
        require_env
        # --at <x> for remove == positional target; if both given, --at wins.
        if [[ -n "$target" ]]; then set -- "$target" "$@"; fi
        cmd_remove "$@"
        ;;
    gc)
        [[ -z "$target" ]] || { echo "gh-wt: --at is not valid with 'gc'" >&2; exit 1; }
        require_env
        cmd_gc
        ;;
    --)
        shift
        require_env
        cmd_exec_in "$target" "$@"
        ;;
    *)
        require_env
        cmd_exec_with "$target" "$@"
        ;;
esac
